# Doc Parser example environment.
# Copy to `.env` for local development and adjust for your machine.

# Dependency policy: install and run the latest compatible package versions.
DOC_PARSER_DEPENDENCY_POLICY=latest

# Server bind address.
# Use 127.0.0.1 for local-only, or 0.0.0.0 when exposing to a LAN/container network.
DOC_PARSER_HOST=127.0.0.1
DOC_PARSER_PORT=8585

# Security: local path ingestion lets API clients read files from the backend host.
# Keep disabled for shared/open-source deployments; upload files through /ingest/upload instead.
DOC_PARSER_ENABLE_LOCAL_PATH_INGEST=false
DOC_PARSER_CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173","http://localhost:5070","http://127.0.0.1:5070"]
DOC_PARSER_CORS_ALLOW_PRIVATE_LAN=false

# Workspace and SQLite database.
DOC_PARSER_WORKSPACE_PATH=workspace
DOC_PARSER_DATABASE_PATH=workspace/doc_parser.db

# MinerU CLI.
# Generic install: keep `mineru` and make sure it is on PATH.
# Project venv install: set `.venv/bin/mineru` when running uvicorn from backend/.
DOC_PARSER_MINERU_CLI_PATH=mineru
DOC_PARSER_MINERU_MODEL_SOURCE=huggingface

# Optional MinerU API/router URL.
# Simple mode: leave empty. The MinerU CLI will auto-start a temporary local API per parse.
# Service mode: start a warm local service, then set e.g. http://127.0.0.1:8601.
# Remote mode: point at a MinerU API/router on another host, e.g. http://gpu-host:8601.
DOC_PARSER_MINERU_API_URL=

# Optional MinerU VLM backend URL for MinerU *-http-client backends.
# Most users can leave these empty; app-level VLM enrichment is configured below.
# DOC_PARSER_MINERU_VLM_URL=http://127.0.0.1:11434/v1
# DOC_PARSER_MINERU_VLM_MODEL_NAME=your-vision-model
# DOC_PARSER_MINERU_VLM_API_KEY=ollama

# App-level VLM enrichment for forms, figures, diagrams, and semantic text.
# Leave reachable from the backend process. Ollama's OpenAI-compatible endpoint is common.
DOC_PARSER_VLM_BASE_URL=http://127.0.0.1:11434/v1
DOC_PARSER_VLM_API_KEY=ollama
DOC_PARSER_VLM_MODEL=

# Optional stronger reviewer model for final quality audit/repair checks.
# Leave empty to reuse the enrichment model.
DOC_PARSER_REVIEW_VLM_BASE_URL=
DOC_PARSER_REVIEW_VLM_API_KEY=
DOC_PARSER_REVIEW_VLM_MODEL=
