FROM python:3.12-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1 \
    DEBIAN_FRONTEND=noninteractive

WORKDIR /app/backend

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        curl \
        git \
        libgl1 \
        libglib2.0-0 \
        libgomp1 \
        libreoffice \
        fonts-noto-cjk \
        poppler-utils \
    && rm -rf /var/lib/apt/lists/*

COPY backend/pyproject.toml ./pyproject.toml
COPY backend/app ./app
COPY backend/tests ./tests

RUN python -m pip install --upgrade pip \
    && python -m pip install -e '.[mineru]'

ENV DOC_PARSER_HOST=0.0.0.0 \
    DOC_PARSER_PORT=8585 \
    DOC_PARSER_WORKSPACE_PATH=/data/workspace \
    DOC_PARSER_DATABASE_PATH=/data/workspace/doc_parser.db \
    DOC_PARSER_ENABLE_LOCAL_PATH_INGEST=false \
    DOC_PARSER_CORS_ORIGINS='["http://localhost:5070","http://127.0.0.1:5070"]' \
    DOC_PARSER_CORS_ALLOW_PRIVATE_LAN=false \
    DOC_PARSER_MINERU_CLI_PATH=mineru \
    DOC_PARSER_MINERU_MODEL_SOURCE=huggingface \
    DOC_PARSER_MINERU_API_URL= \
    DOC_PARSER_VLM_BASE_URL=http://host.docker.internal:11434/v1 \
    DOC_PARSER_VLM_API_KEY=ollama \
    DOC_PARSER_VLM_MODEL= \
    DOC_PARSER_REVIEW_VLM_BASE_URL= \
    DOC_PARSER_REVIEW_VLM_API_KEY= \
    DOC_PARSER_REVIEW_VLM_MODEL=
RUN mkdir -p /data/workspace /root/.cache

EXPOSE 8585

HEALTHCHECK --interval=30s --timeout=5s --start-period=30s --retries=3 \
    CMD curl -fsS "http://127.0.0.1:${DOC_PARSER_PORT:-8585}/api/health" || exit 1

CMD ["sh", "-c", "python -m uvicorn app.main:app --host ${DOC_PARSER_HOST:-0.0.0.0} --port ${DOC_PARSER_PORT:-8585}"]
